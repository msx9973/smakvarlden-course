# Local API
PORT=5000
SESSION_SECRET=replace-with-a-long-random-secret

# Supabase Postgres database.
# Use Supabase Dashboard > Project Settings > Database > Connection string.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-north-1.pooler.supabase.com:6543/postgres

# Supabase Auth / Google login.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Spoonacular must stay server-side. Do not expose this with VITE_.
SPOONACULAR_API_KEY=YOUR_SPOONACULAR_KEY

# Frontend API URL for hosted builds.
# Local dev can leave this empty because Vite proxies /api to localhost:5000.
VITE_API_URL=
